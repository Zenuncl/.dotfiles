#!/usr/bin/env bash
set -euo pipefail

# Default paths — override via env vars
AGE_RECIPIENTS_FILE="${AGE_RECIPIENTS_FILE:-${HOME}/.secrets/age/age-recipients.txt}"
AGE_KEYFILE="${AGE_KEYFILE:-}"

usage() {
    cat <<EOF
Usage: $(basename "$0") --encrypt <file|dir> [--recipient <pubkey>]
       $(basename "$0") --decrypt <file.age> [--keyfile <identity>]

Options:
  --encrypt <file|dir>    Encrypt a file or directory (.age output)
  --decrypt <file.age>    Decrypt an age-encrypted file
  --recipient <pubkey>    Recipient public key (encrypt; overrides default)
  --keyfile <path>        Identity file (decrypt; overrides \$AGE_KEYFILE)
  --help                  Show this help

Environment:
  AGE_KEYFILE             Default identity file for decryption
  AGE_RECIPIENTS_FILE     Default recipients file (default: ~/.secrets/age/age-recipients.txt)
EOF
    exit 1
}

if ! command -v age &>/dev/null; then
    echo "Error: 'age' is not installed." >&2
    exit 1
fi

# ─── Parse arguments ──────────────────────────────────────────────────────────

MODE=""
FILE=""
RECIPIENT=""
KEYFILE_ARG=""

while [[ $# -gt 0 ]]; do
    case $1 in
        --encrypt)  MODE="encrypt"; FILE="${2:?'--encrypt requires a file/dir'}"; shift ;;
        --decrypt)  MODE="decrypt"; FILE="${2:?'--decrypt requires a file'}";     shift ;;
        --recipient) RECIPIENT="${2:?'--recipient requires a value'}";             shift ;;
        --keyfile)  KEYFILE_ARG="${2:?'--keyfile requires a path'}";              shift ;;
        --help)     usage ;;
        *)          echo "Unknown option: $1" >&2; usage ;;
    esac
    shift
done

[[ -z "${MODE}" ]] && { echo "Error: specify --encrypt or --decrypt." >&2; usage; }
[[ -z "${FILE}" ]] && { echo "Error: no file specified." >&2; usage; }

# ─── Encrypt ──────────────────────────────────────────────────────────────────

if [[ "${MODE}" == "encrypt" ]]; then
    [[ -e "${FILE}" ]] || { echo "Error: '${FILE}' not found." >&2; exit 1; }

    FILEDIR="$(dirname "${FILE}")"
    BASE="$(basename "${FILE}")"

    # Build age recipient args
    if [[ -n "${RECIPIENT}" ]]; then
        AGE_ARGS=(--recipient "${RECIPIENT}")
        echo "Encrypting for recipient: ${RECIPIENT}"
    elif [[ -f "${AGE_RECIPIENTS_FILE}" ]]; then
        AGE_ARGS=(--recipients-file "${AGE_RECIPIENTS_FILE}")
        echo "Encrypting using recipients file: ${AGE_RECIPIENTS_FILE}"
    else
        read -rp "Enter recipient public key (age1...): " RECIPIENT
        [[ -z "${RECIPIENT}" ]] && { echo "Error: recipient required." >&2; exit 1; }
        AGE_ARGS=(--recipient "${RECIPIENT}")
    fi

    if [[ -d "${FILE}" ]]; then
        # Directory — tar (gzip) first, then encrypt
        # Naming: test-dir -> test-dir.gz.tar -> test-dir.gz.tar.age
        TAR_OUTPUT="${FILEDIR}/${BASE}.gz.tar"
        OUTPUT="${TAR_OUTPUT}.age"
        echo "Directory detected — archiving to ${TAR_OUTPUT}…"
        tar czf "${TAR_OUTPUT}" -C "${FILEDIR}" "${BASE}"
        echo "Encrypting to ${OUTPUT}…"
        age "${AGE_ARGS[@]}" --output "${OUTPUT}" "${TAR_OUTPUT}"
        rm -f "${TAR_OUTPUT}"
    else
        # Plain file — encrypt directly; saved alongside original
        OUTPUT="${FILEDIR}/${BASE}.age"
        echo "File detected — encrypting to ${OUTPUT}…"
        age "${AGE_ARGS[@]}" --output "${OUTPUT}" "${FILE}"
    fi

    echo "Encrypted: ${OUTPUT}"

# ─── Decrypt ──────────────────────────────────────────────────────────────────

elif [[ "${MODE}" == "decrypt" ]]; then
    [[ -f "${FILE}" ]] || { echo "Error: '${FILE}' not found." >&2; exit 1; }

    # Resolve identity file: --keyfile > $AGE_KEYFILE > prompt
    if [[ -n "${KEYFILE_ARG}" ]]; then
        KEYFILE="${KEYFILE_ARG}"
    elif [[ -n "${AGE_KEYFILE}" ]]; then
        KEYFILE="${AGE_KEYFILE}"
        echo "Using keyfile: ${KEYFILE}"
    else
        read -rp "Enter path to identity (key) file: " KEYFILE
        [[ -z "${KEYFILE}" ]] && { echo "Error: keyfile required." >&2; exit 1; }
    fi

    [[ -f "${KEYFILE}" ]] || { echo "Error: keyfile '${KEYFILE}' not found." >&2; exit 1; }

    DECRYPTED="${FILE%.age}"
    age --decrypt --identity "${KEYFILE}" --output "${DECRYPTED}" "${FILE}"
    echo "Decrypted: ${DECRYPTED}"

    # Extract only if it's a gzip tar (created with tar czf)
    MIME="$(file --mime-type -b "${DECRYPTED}")"
    if [[ "${MIME}" == "application/gzip" || "${MIME}" == "application/x-gzip" ]]; then
        echo "Detected gzip tar archive, extracting…"
        tar xzf "${DECRYPTED}" && rm -f "${DECRYPTED}"
    else
        echo "Not a tar archive (${MIME}), leaving as-is."
    fi
fi
