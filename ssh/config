# Dev: Local Development Server (*.dev)(*.local) | Person VM Servers (*.vm)
# Prd: Productions Servers (*.prd)(*.work)
# Office Server (*.office)
# Others Config (Linode, Github etc)
Include config.d/*.conf

# Global Configs
Host *
  ForwardAgent yes
  StrictHostKeyChecking no
  UserKnownHostsFile /dev/null
  SetEnv TERM=xterm-256color

# Github Configs
Host github.com
  IdentityFile ~/.ssh/secrets/keys.sec/github.ed25519.pem
